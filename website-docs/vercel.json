{
  "framework": null,
  "buildCommand": "mkdir -p md && cp ../docs/*.md md/ && bash ../scripts/build-llms-full.sh ../docs llms-full.txt && cp ../skills/ows/SKILL.md SKILL.md",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/llms-full.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/SKILL.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    }
  ]
}
